# envsubst用のデフォルトテンプレート
# SSL_ENABLED=true の場合、ssl.conf.templateを使用

# SSLリダイレクト設定（SSL有効時）
set $ssl_enabled_redir "";
set $ssl_enabled_server "";

if ( "${SSL_ENABLED}" = "true" ) {
    set $ssl_enabled_redir "return 301 https://$host$request_uri;";
    set $ssl_enabled_server "include /etc/nginx/templates/ssl-server.conf;";
}
